export PATH="$HOME/.cargo/bin:$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

if command -v nvim > /dev/null 2>&1 ; then
    export EDITOR='nvim'
elif command -v vim > /dev/null 2>&1 ; then
    export EDITOR='vim'
elif command -v nano > /dev/null 2>&1 ; then
    export EDITOR='nano'
fi

. "$HOME/.aliases"

